{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TubeSaver",
  "version": "0.1.0",
  "identifier": "com.manomekun.tubesaver",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "TubeSaver",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "category": "Utility",
    "shortDescription": "YouTube video downloader powered by yt-dlp",
    "longDescription": "A desktop application for downloading YouTube videos and audio with a modern UI. Supports MP4/MP3 formats, parallel downloads, and Adobe Premiere compatible codecs."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
